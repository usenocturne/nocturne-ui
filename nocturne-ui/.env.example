# Shared Spotify Client ID (always available as fallback)
VITE_SPOTIFY_CLIENT_ID_SHARED=65b708073fc0480ea92a077233ca87bd

# Your own Spotify Client ID (optional - overrides shared)
# To get your own:
# 1. Go to https://developer.spotify.com/dashboard
# 2. Click "Create App"
# 3. Set Redirect URI to: http://127.0.0.1:5000/auth/callback
# 4. Check "Web API" and "Web Playback SDK"
# 5. Copy the Client ID from app settings
VITE_SPOTIFY_CLIENT_ID=
